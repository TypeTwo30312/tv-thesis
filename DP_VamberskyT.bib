  shorttitle = {{{JASPAR}} 2026},
  author = {Ovek Baydar, Damla and Rauluseviciute, Ieva and Aronsen, Dina R. and {Blanc-Mathieu}, Romain and Bonthuis, Ine and {de Beukelaer}, Herman and Ferenc, Katalin and Jegou, Alice and Kumar, Vipin and Lemma, Roza Berhanu and Lucas, J{\'e}r{\'e}my and Pochon, Mathis and Yun, Chang M. and Ramalingam, Vivekanandan and Deshpande, Salil Sanjay and Patel, Aman and Marinov, Georgi K. and Wang, Austin T. and Aguirre, Alejandro and {Castro-Mondragon}, Jaime A. and Baranasic, Damir and Ch{\`e}neby, Jeanne and Gundersen, Sveinung and Johansen, Morten and Khan, Aziz and Kuijjer, Marieke L. and Hovig, Eivind and Lenhard, Boris and Sandelin, Albin and Vandepoele, Klaas and Wasserman, Wyeth W. and Parcy, Fran{\c c}ois and Kundaje, Anshul and Mathelier, Anthony},
  year = 2026,
  month = jan,
  journal = {Nucleic Acids Research},
  volume = {54},
  number = {D1},
  pages = {D184-D193},
  issn = {1362-4962},
  doi = {10.1093/nar/gkaf1209},
  abstract = {JASPAR (https://jaspar.elixir.no/) is an open-access database that has provided high-quality, manually curated, and non-redundant DNA binding profiles for transcription factors (TFs) as position frequency matrices (PFMs) for over 20 years. We expanded the CORE (306 new profiles, 12\% increase) and UNVALIDATED (433, 60\% increase) collections with new PFMs and updated 13 existing profiles. We updated the TF binding site predictions and genome tracks for eight species. TF binding profile clusters and familial TF binding sites were updated accordingly. We integrate the inMOTIFin software to easily simulate regulatory sequences using JASPAR PFMs. To enrich TFs' annotations, we provide scientific literature-based human TF target information. Notably, this release features a deep learning (DL) collection, providing a paradigm shift in modeling and characterizing TF-DNA interactions with 1259 BPNet models trained on Homo sapiens ENCODE chromatin immunoprecipitation followed by sequencing (ChIP-seq) datasets from 240 TFs and interpreted to reveal predictive motif patterns for the models. The motifs associated with the same TF were clustered to provide a summary of the binding properties, resulting in 240 primary and 113 alternative motif patterns in the DL collection. The JASPAR 2026 collections lay a foundation for future endeavors in genomic research, serving the scientific community in uncovering the mechanisms of gene regulation.},
  langid = {english},
  pmcid = {PMC12807658},
  pmid = {41325984},
  keywords = {Animals,Binding Sites,Chromatin Immunoprecipitation Sequencing,Computational Biology,Databases Genetic,Deep Learning,DNA,Humans,Nucleotide Motifs,Protein Binding,Software,Transcription Factors},
  file = {/home/vambersky_t/Zotero/storage/IY3PFF43/Ovek Baydar et al. - 2025 - JASPAR 2026 expansion of transcription factor binding profiles and integration of deep learning mod.pdf;/home/vambersky_t/Zotero/storage/WUN5M6WY/Ovek Baydar et al. - 2026 - JASPAR 2026 expansion of transcription factor binding profiles and integration of deep learning mod.pdf}
