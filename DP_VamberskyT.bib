}

@article{
  title = {The Gene Regulation Knowledge Commons: The Action Area of {{GREEKC}}},
  shorttitle = {The Gene Regulation Knowledge Commons},
  author = {Kuiper, Martin and Bonello, Joseph and {Fern{\'a}ndez-Breis}, Jesualdo T. and Bucher, Philipp and Futschik, Matthias E. and Gaudet, Pascale and Kulakovskiy, Ivan V. and Licata, Luana and Logie, Colin and Lovering, Ruth C. and Makeev, Vsevolod J. and Orchard, Sandra and Panni, Simona and Perfetto, Livia and Sant, David and Schulz, Stefan and Vercruysse, Steven and Zerbino, Daniel R. and L{\ae}greid, Astrid and {GRECO Consortium}},
