@article{vorontsovHOCOMOCO2024Rebuild2024,
  title = {{{HOCOMOCO}} in 2024: A Rebuild of the Curated Collection of Binding Models for Human and Mouse Transcription Factors},
  shorttitle = {{{HOCOMOCO}} in 2024},
  author = {Vorontsov, Ilya E and Eliseeva, Irina A and Zinkevich, Arsenii and Nikonov, Mikhail and Abramov, Sergey and Boytsov, Alexandr and Kamenets, Vasily and Kasianova, Alexandra and Kolmykov, Semyon and Yevshin, Ivan~S and Favorov, Alexander and Medvedeva, Yulia A and Jolma, Arttu and Kolpakov, Fedor and Makeev, Vsevolod~J and Kulakovskiy, Ivan~V},
