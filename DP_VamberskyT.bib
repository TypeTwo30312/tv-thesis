  pmid = {34757206},
  keywords = {Biocuration,Computational biology,Gene Expression Regulation,Knowledge Commons,Ontologies,Reproducibility of Results,Text mining,Web services},
  file = {/home/vambersky_t/Zotero/storage/ACB7H9PL/Kuiper et al. - 2022 - The gene regulation knowledge commons the action area of GREEKC.pdf}
